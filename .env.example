# Target IoT device and optional MQTT broker
ESP_IP=192.168.151.210
BROKER_IP=192.168.150.137
TCP_PORT=9000

# Linux/Mininet network settings
UPLINK=enp0s3
IFACE=nat0-eth0
CONTROLLER_IP=

# Project paths, relative to the repository when commands are run from the project root
PROJECT_DIR=.
PCAP_DIR=/tmp/ids_live_pcaps
CSV_DIR=csv
CICFLOW=cicflowmeter

# Spark model and checkpoint paths
MODEL_PATH=RF-20
CIC_SCHEMA=cic_schema.json
CHECKPOINT=checkpoints/ids_stream

# PostgreSQL output
PG_HOST=localhost
PG_PORT=5433
PG_DB=mlanalytics
PG_USER=mluser
PG_PASS=mlpass
PG_TABLE=ids_alerts

# Rule thresholds for 10-second windows
PORTSCAN_PORTS=50
DOS_FLOWS=200
DOS_PKTS=1000
WEB_VOTES=5
BOT_VOTES=5
HB_VOTES=1
INFL_VOTES=2
